# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is gitignored so your keys never get committed.
#
# In production (Cloudflare Pages), set these same names as
# environment variables in: Pages project → Settings → Environment variables.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
